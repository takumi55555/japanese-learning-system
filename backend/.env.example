# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/education
# PROD_MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/education

# JWT
JWT_SECRET=your_jwt_secret_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Admin (default admin account created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_ROLE=admin

# Frontend URL (for Stripe redirect etc.)
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated additional origins)
PROD_CORS_ORIGIN=http://localhost:5173,http://localhost:3000
